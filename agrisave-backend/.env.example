# Server Configuration
NODE_ENV=production
PORT=5000

# JWT Secrets - WAJIB DIGANTI dengan nilai random yang kuat!
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_REFRESH_SECRET=your_refresh_secret_jwt_key_min_32_chars_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Database (SQLite for local, replace with PostgreSQL URI for cloud)
DB_PATH=./data/agrisave.db

# Encryption Master Key (32 bytes / 256-bit)
SYSTEM_MASTER_KEY=your_256bit_system_master_key_here_change_this
PBKDF2_ITERATIONS=310000
PBKDF2_KEYLEN=32

# CORS - URL frontend Anda
FRONTEND_URL=https://your-frontend.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5

# bcrypt rounds (12 = secure, 14 = very secure but slower)
BCRYPT_SALT_ROUNDS=12
